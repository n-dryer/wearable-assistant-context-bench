cff-version: 1.2.0
message: "If you reference the Wearable Assistant Context Benchmark, cite this file with the exact release tag."
title: "Wearable Assistant Context Benchmark"
abstract: "Benchmark for implicit context tracking in wearable multimodal assistants. Developed around a wearable multimodal assistant and applicable to related multimodal assistant devices on or near the user. v1 measures reference-state selection under implicit context shift on a frozen 11-scenario set."
authors:
  - family-names: "Dryer"
    given-names: "Nate"
repository-code: "https://github.com/n-dryer/wearable-assistant-context-bench"
url: "https://github.com/n-dryer/wearable-assistant-context-bench"
keywords:
  - implicit context tracking
  - wearable multimodal assistant
  - multimodal assistant device
  - reference-state selection
  - context inference
  - context shift
  - LLM-as-judge
license: "MIT"
