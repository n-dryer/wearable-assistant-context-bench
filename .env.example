# Required when the candidate model or judge is Claude-family.
ANTHROPIC_API_KEY=your_key_here

# Required when the candidate model or judge is Gemini-family.
# `GOOGLE_API_KEY` and `GOOGLE_GENAI_API_KEY` are also accepted.
GEMINI_API_KEY=your_key_here

# Required when using OpenAI models through the LiteLLM-backed path.
OPENAI_API_KEY=your_key_here

# Required when using OpenRouter-backed models through LiteLLM.
OPENROUTER_API_KEY=your_key_here

# Required when running candidate models via Hugging Face Inference
# Providers (router.huggingface.co). Generate a fine-grained token at
# huggingface.co/settings/tokens with "Make calls to Inference Providers"
# permission. HF Pro accounts get included Inference Provider credits each
# month (additional usage billed at provider rates with no markup).
#
# Use the model id format `huggingface/<inference_provider>/<hf_org>/<hf_model>`,
# e.g. `huggingface/together/Qwen/Qwen2.5-VL-7B-Instruct`. LiteLLM reads
# `HF_TOKEN`; `HUGGINGFACE_API_KEY` is also accepted.
HF_TOKEN=your_token_here
HUGGINGFACE_API_KEY=your_token_here
