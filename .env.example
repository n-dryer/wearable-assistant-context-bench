# Required when the candidate model or judge is Claude-family, and
# when the resolved judge family is `claude` (default when candidate
# is GPT-family under --judge-family auto).
ANTHROPIC_API_KEY=your_key_here

# Required when the resolved judge family is `openai`. This is the
# default when the candidate is Claude-family under
# --judge-family auto. Optional otherwise.
OPENAI_API_KEY=your_key_here

# Required when the candidate model or explicit judge is Gemini-family.
GEMINI_API_KEY=your_key_here
